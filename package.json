{
  "name": "qianfo",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "description": "千佛预约系统",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "scripts": {
    "dev:h5": "pnpm --filter h5 dev",
    "dev:web": "pnpm --filter web dev",
    "build:h5": "pnpm --filter h5 build",
    "build:web": "pnpm --filter web build",
    "build": "pnpm --filter @qianfo/shared build || true && pnpm --filter h5 build && pnpm --filter web build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:type": "pnpm --filter h5 exec vue-tsc && pnpm --filter web exec vue-tsc",
    "check:type:h5": "pnpm --filter h5 exec vue-tsc",
    "check:type:web": "pnpm --filter web exec vue-tsc",
    "check:style": "prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "lodash-es": "^4.17.23"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@sentry/vite-plugin": "4.2.0",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,vue}": "eslint --fix"
  }
}
